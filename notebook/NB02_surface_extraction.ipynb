{
 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# NB02 — Surface Extraction & Pivot to Wide Format\n",
    "\n",
    "**Objective**:  \n",
    "1. Read all `output_data_points.csv` from ZIP archives (long format)  \n",
    "2. Extract the surface soil layer (upper_depth ≤ 10 cm)  \n",
    "3. Where multiple depth intervals exist for the same station+property, apply depth-weighted mean  \n",
    "4. Pivot from long format (one row = one measurement) to wide format (one row = one station)  \n",
    "5. Attach country/ISO3 from NB01 audit  \n",
    "\n",
    "**Inputs**:  \n",
    "- `data/country/*` (ZIP archives)  \n",
    "- `data/intermediate/audit/zip_inventory.csv`  \n",
    "\n",
    "**Outputs**:  \n",
    "- `data/intermediate/wosis_surface_long.parquet` — filtered long format (surface only)  \n",
    "- `data/intermediate/wosis_surface_wide.parquet` — one row per station, properties as columns  \n",
    "- `data/intermediate/wosis_surface_flags.parquet` — per station × property: depth_method, n_depth_intervals  \n",
    "- `logs/nb02_surface_extraction.log`  \n",
    "\n",
    "**STOP conditions**:  \n",
    "- If output row count < 80% of expected unique stations from NB01 → STOP  \n",
    "- If pivot produces columns other than expected properties → STOP  "
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import zipfile\n",
    "import io\n",
    "import logging\n",
    "from pathlib import Path\n",
    "from datetime import datetime\n",
    "\n",
    "import pandas as pd\n",
    "import numpy as np\n",
    "\n",
    "# ── Paths ──────────────────────────────────────────────────────────────────\n",
    "BASE         = Path('/home/agbelgaid/Documents/WORKSPACE/DataCollection/SoilHive')\n",
    "COUNTRY_DIR  = BASE / 'data' / 'country'\n",
    "INTER_DIR    = BASE / 'data' / 'intermediate'\n",
    "AUDIT_DIR    = INTER_DIR / 'audit'\n",
    "LOG_DIR      = BASE / 'logs'\n",
    "\n",
    "# ── Logging ────────────────────────────────────────────────────────────────\n",
    "log_path = LOG_DIR / 'nb02_surface_extraction.log'\n",
    "logging.basicConfig(\n",
    "    level=logging.INFO,\n",
    "    format='%(asctime)s [%(levelname)s] %(message)s',\n",
    "    handlers=[\n",
    "        logging.FileHandler(log_path, mode='w'),\n",
    "        logging.StreamHandler()\n",
    "    ]\n",
    ")\n",
    "log = logging.getLogger('nb02')\n",
    "log.info(f'NB02 started at {datetime.now().isoformat()}')\n",
    "\n",
    "# ── Constants ──────────────────────────────────────────────────────────────\n",
    "SURFACE_UPPER_DEPTH_MAX = 10    # cm — maximum upper_depth to qualify as surface\n",
    "SURFACE_LOWER_DEPTH_MAX = 15    # cm — maximum lower_depth for single-layer acceptance\n",
    "\n",
    "PROPERTIES = [\n",
    "    'BD', 'Ca', 'CaCO3', 'CEC', 'CF', 'clay', 'EC', 'K',\n",
    "    'Mg', 'N', 'Na', 'nematode', 'occ', 'P', 'pH', 'sand',\n",
    "    'silt', 'TC', 'WR_gravimetric', 'WR_volumetric'\n",
    "]"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load inventory from NB01 ───────────────────────────────────────────────\n",
    "inventory = pd.read_csv(AUDIT_DIR / 'zip_inventory.csv')\n",
    "csv_zips = inventory[inventory['has_csv'] == True].copy()\n",
    "log.info(f'NB01 inventory loaded: {len(csv_zips)} ZIPs with CSV data')\n",
    "\n",
    "# Build hash → country mapping\n",
    "hash_to_meta = csv_zips.set_index('zip_hash')[['country', 'iso3']].to_dict(orient='index')\n",
    "\n",
    "expected_total_stations = csv_zips['n_stations'].sum()\n",
    "log.info(f'Expected total unique stations (from NB01): {expected_total_stations:,}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Load all CSVs and extract surface layer ────────────────────────────────\n",
    "surface_chunks = []\n",
    "flag_chunks    = []\n",
    "\n",
    "for _, inv_row in csv_zips.iterrows():\n",
    "    zip_hash = inv_row['zip_hash']\n",
    "    zip_path = COUNTRY_DIR / zip_hash\n",
    "    country  = inv_row['country']\n",
    "    iso3     = inv_row['iso3']\n",
    "    \n",
    "    try:\n",
    "        with zipfile.ZipFile(zip_path, 'r') as zf:\n",
    "            with zf.open('output_data_points.csv') as f:\n",
    "                df = pd.read_csv(\n",
    "                    io.TextIOWrapper(f, encoding='utf-8'),\n",
    "                    low_memory=False\n",
    "                )\n",
    "        \n",
    "        df['zip_hash'] = zip_hash\n",
    "        df['country']  = country\n",
    "        df['iso3']     = iso3\n",
    "        \n",
    "        # Cast depth columns\n",
    "        df['upper_depth_cm'] = pd.to_numeric(df['upper_depth_cm'], errors='coerce')\n",
    "        df['lower_depth_cm'] = pd.to_numeric(df['lower_depth_cm'], errors='coerce')\n",
    "        df['value']          = pd.to_numeric(df['value'], errors='coerce')\n",
    "        \n",
    "        # Surface filter: upper_depth <= SURFACE_UPPER_DEPTH_MAX\n",
    "        surface = df[df['upper_depth_cm'] <= SURFACE_UPPER_DEPTH_MAX].copy()\n",
    "        \n",
    "        n_before = df[['lat', 'lon']].drop_duplicates().shape[0]\n",
    "        n_after  = surface[['lat', 'lon']].drop_duplicates().shape[0]\n",
    "        \n",
    "        log.info(f'  {zip_hash} ({country}): {n_before} stations → {n_after} have surface records')\n",
    "        \n",
    "        surface_chunks.append(surface)\n",
    "    \n",
    "    except Exception as e:\n",
    "        log.error(f'  ERROR loading {zip_hash}: {e}')\n",
    "        continue\n",
    "\n",
    "log.info('All ZIPs loaded. Concatenating...')\n",
    "df_long = pd.concat(surface_chunks, ignore_index=True)\n",
    "log.info(f'Long surface DataFrame: {len(df_long):,} rows')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Depth-weighted mean aggregation ───────────────────────────────────────\n",
    "# For each (lat, lon, iso3, property): compute depth-weighted mean across all\n",
    "# surface intervals (upper_depth <= 10 cm)\n",
    "\n",
    "def depth_weighted_mean(group):\n",
    "    \"\"\"\n",
    "    Compute thickness-weighted mean of 'value' over depth intervals.\n",
    "    Only rows where value is not NaN are included.\n",
    "    \"\"\"\n",
    "    g = group.dropna(subset=['value', 'upper_depth_cm', 'lower_depth_cm'])\n",
    "    if len(g) == 0:\n",
    "        return pd.Series({\n",
    "            'value': np.nan,\n",
    "            'depth_method': 'no_valid_obs',\n",
    "            'n_depth_intervals': 0,\n",
    "            'effective_upper_cm': np.nan,\n",
    "            'effective_lower_cm': np.nan\n",
    "        })\n",
    "    \n",
    "    g = g.copy()\n",
    "    g['thickness'] = g['lower_depth_cm'] - g['upper_depth_cm']\n",
    "    g = g[g['thickness'] > 0]  # skip zero-thickness intervals\n",
    "    \n",
    "    if len(g) == 0:\n",
    "        return pd.Series({\n",
    "            'value': np.nan,\n",
    "            'depth_method': 'zero_thickness',\n",
    "            'n_depth_intervals': 0,\n",
    "            'effective_upper_cm': np.nan,\n",
    "            'effective_lower_cm': np.nan\n",
    "        })\n",
    "    \n",
    "    total_thickness = g['thickness'].sum()\n",
    "    weighted_value  = (g['value'] * g['thickness']).sum() / total_thickness\n",
    "    \n",
    "    method = 'single' if len(g) == 1 else 'depth_weighted_mean'\n",
    "    \n",
    "    return pd.Series({\n",
    "        'value': weighted_value,\n",
    "        'depth_method': method,\n",
    "        'n_depth_intervals': len(g),\n",
    "        'effective_upper_cm': g['upper_depth_cm'].min(),\n",
    "        'effective_lower_cm': g['lower_depth_cm'].max()\n",
    "    })\n",
    "\n",
    "log.info('Computing depth-weighted means per station × property...')\n",
    "\n",
    "GROUP_KEYS = ['lat', 'lon', 'iso3', 'country', 'zip_hash', 'property']\n",
    "agg = df_long.groupby(GROUP_KEYS, sort=False).apply(depth_weighted_mean).reset_index()\n",
    "\n",
    "log.info(f'Aggregated: {len(agg):,} rows (station × property combinations)')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Pivot to wide format ───────────────────────────────────────────────────\n",
    "log.info('Pivoting to wide format...')\n",
    "\n",
    "# Keep flags in a separate table before pivot\n",
    "df_flags = agg[['lat', 'lon', 'iso3', 'country', 'zip_hash', 'property',\n",
    "                 'depth_method', 'n_depth_intervals',\n",
    "                 'effective_upper_cm', 'effective_lower_cm']].copy()\n",
    "\n",
    "# Pivot values\n",
    "df_wide = agg.pivot_table(\n",
    "    index=['lat', 'lon', 'iso3', 'country', 'zip_hash'],\n",
    "    columns='property',\n",
    "    values='value',\n",
    "    aggfunc='first'   # should be 1-to-1 after depth aggregation\n",
    ").reset_index()\n",
    "\n",
    "# Flatten column names\n",
    "df_wide.columns.name = None\n",
    "\n",
    "# Ensure all expected property columns exist (fill missing with NaN)\n",
    "for prop in PROPERTIES:\n",
    "    if prop not in df_wide.columns:\n",
    "        df_wide[prop] = np.nan\n",
    "        log.warning(f'Property \"{prop}\" not found in any ZIP — column added as NaN')\n",
    "\n",
    "# Add station_id (stable unique identifier)\n",
    "df_wide = df_wide.reset_index(drop=True)\n",
    "df_wide.insert(0, 'station_id', df_wide.index.astype(str).str.zfill(6))\n",
    "\n",
    "log.info(f'Wide DataFrame: {len(df_wide):,} stations × {len(df_wide.columns)} columns')\n",
    "print(f'Columns: {list(df_wide.columns)}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── STOP CONDITION ─────────────────────────────────────────────────────────\n",
    "n_output_stations = len(df_wide)\n",
    "pct_recovered = 100 * n_output_stations / expected_total_stations if expected_total_stations > 0 else 0\n",
    "\n",
    "print(f'Expected stations (NB01): {expected_total_stations:,}')\n",
    "print(f'Output stations (NB02) : {n_output_stations:,}')\n",
    "print(f'Recovery rate          : {pct_recovered:.1f}%')\n",
    "\n",
    "assert pct_recovered >= 80, (\n",
    "    f'STOP: Only {pct_recovered:.1f}% of expected stations recovered '\n",
    "    f'(threshold=80%). Investigate surface filter and CSV loading.'\n",
    ")\n",
    "\n",
    "# Unexpected property columns\n",
    "extra_cols = [c for c in df_wide.columns\n",
    "              if c not in PROPERTIES + ['station_id', 'lat', 'lon', 'iso3', 'country', 'zip_hash']]\n",
    "if extra_cols:\n",
    "    log.warning(f'Unexpected columns in wide table: {extra_cols}')\n",
    "    print(f'WARNING: Unexpected columns: {extra_cols}')"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# ── Save outputs ───────────────────────────────────────────────────────────\n",
    "df_long.to_parquet(INTER_DIR / 'wosis_surface_long.parquet', index=False)\n",
    "df_wide.to_parquet(INTER_DIR / 'wosis_surface_wide.parquet', index=False)\n",
    "df_flags.to_parquet(INTER_DIR / 'wosis_surface_flags.parquet', index=False)\n",
    "\n",
    "log.info(f'Saved: wosis_surface_long.parquet  ({len(df_long):,} rows)')\n",
    "log.info(f'Saved: wosis_surface_wide.parquet  ({len(df_wide):,} rows)')\n",
    "log.info(f'Saved: wosis_surface_flags.parquet ({len(df_flags):,} rows)')\n",
    "\n",
    "# Print summary\n",
    "print('\\n=== NB02 SUMMARY ===')\n",
    "print(f'Surface records (long) : {len(df_long):,}')\n",
    "print(f'Unique stations (wide) : {len(df_wide):,}')\n",
    "print(f'Countries              : {df_wide[\"iso3\"].nunique()}')\n",
    "print(f'\\nProperty completeness (% non-null stations):')\n",
    "for prop in PROPERTIES:\n",
    "    if prop in df_wide.columns:\n",
    "        pct = 100 * df_wide[prop].notna().mean()\n",
    "        print(f'  {prop:20s}: {pct:5.1f}%')\n",
    "\n",
    "log.info('NB02 completed successfully — proceed to NB03')"
   ]
  }
 ],
 "metadata": {\n  \"kernelspec\": {\"display_name\": \"Python 3\", \"language\": \"python\", \"name\": \"python3\"},\n  \"language_info\": {\"name\": \"python\", \"version\": \"3.10.0\"}\n },\n \"nbformat\": 4,\n \"nbformat_minor\": 5\n}
